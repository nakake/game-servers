# ============================================================
# 機密情報 (絶対にコミットしない)
# ============================================================
.secrets/
*.pem
*.key
*.p12
*.pfx
.env
.env.*
!.env.example
.dev.vars
.dev.vars.*
!.dev.vars.example

# AWS
.aws/credentials
.aws/config

# Cloudflare Workers ローカル
.wrangler/
wrangler.toml.local

# Phase 1 検証用の throwaway 秘密鍵 (Discord 署名検証テスト)
.discord-test-keypair.json

# Phase 5 検証用のローカル OIDC private JWK (scripts/sign-test-jwt.mjs 経由で AWS CLI 検証時に作成)。
# 検証後すぐ削除する運用だが、誤コミット防止のため defensive に ignore する。
test-jwk.json
test-jwt.txt

# ============================================================
# Node.js / pnpm
# ============================================================
node_modules/
.pnpm-store/
.pnpm-debug.log*
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ビルド成果物
dist/
build/
out/
.turbo/
.cache/
*.tsbuildinfo
# Phase 3 Step 7: scripts/build-sidecar-ami.ps1 の中間生成物 (sidecar-image.tar) 置き場
.build/

# ============================================================
# TypeScript / JS
# ============================================================
*.js.map
*.d.ts.map
coverage/
.nyc_output/

# ============================================================
# Terraform
# ============================================================
.terraform/
# .terraform.lock.hcl は commit する (provider バージョン固定・再現性 — HashiCorp 推奨)
*.tfstate
*.tfstate.*
*.tfvars
!*.tfvars.example
# 保存済み plan ファイル (機微な値を含みうる)
tfplan
*.tfplan
crash.log
crash.*.log
override.tf
override.tf.json
*_override.tf
*_override.tf.json
.terraformrc
terraform.rc

# ============================================================
# Packer
# ============================================================
packer_cache/
*.box
manifest.json
crash.log

# ============================================================
# エディタ / OS
# ============================================================
.idea/
.vscode/
!.vscode/extensions.json
!.vscode/settings.shared.json
# Claude Code のローカル作業ディレクトリ (将来 add される事故を防ぐ defensive ignore)
.claude/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
Desktop.ini
$RECYCLE.BIN/

# ============================================================
# ログ / 一時ファイル
# ============================================================
*.log
logs/
tmp/
temp/
.tmp/

# ============================================================
# ゲームデータ (リポジトリで管理しない)
# ============================================================
# world/ や save/ は EBS snapshot で管理する
games/*/world/
games/*/saves/
games/*/world_backup/

# ローカル検証用にダウンロードしたmodpack
games/*/modpack-cache/
*.tar.zst
*.tar.gz
!games/_template/**/*.tar.gz.example

# ============================================================
# その他
# ============================================================
.history/
.task-master-ai/
