# ローカル Docker Compose 用の環境変数。
# このファイルを `.env` にコピーして使う。`.env` は .gitignore 済み。

# RCON 接続パスワード (ローカル検証用、本番は SSM Parameter Store)
RCON_PASSWORD=localdev-changeme

# ATM11 サーバーデータ (mods/, libraries/, world/ などを含む) のホスト側パス。
# 省略時は F:/Games/minecraft/ATM/ATM11 (Windows ローカル想定)。
# EC2 では /opt/atm11 など実 EBS マウント先に書き換える。
# ATM11_DATA_DIR=/opt/atm11
