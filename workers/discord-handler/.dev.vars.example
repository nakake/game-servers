# Wrangler ローカル開発用シークレット。
# このファイルを `.dev.vars` にコピーして実値を入れる。`.dev.vars` は .gitignore 済み。
# 本番は `pnpm wrangler secret put NAME` で Cloudflare 側に投入する。

# ---- Phase 1 検証専用 (Phase 2 で削除) ----
# /admin/* endpoint の Bearer 認証トークン。ローカル開発の固有値を入れる。
ADMIN_API_KEY=local-dev-changeme

# ---- AWS リージョン ----
# Worker 本体は OIDC AssumeRoleWithWebIdentity で 15min 短期 credentials を取得する
# (Phase 5 で長期 IAM key は撤去済 = AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY は不要)。
# code は env.AWS_REGION ?? 'ap-northeast-1' で fallback するので未指定でも動く。
AWS_REGION=ap-northeast-1

# ---- Discord ----
# Discord Developer Portal → Application → General Information → Public Key (hex 64文字)
# ローカル検証時はテスト用 ed25519 鍵ペアの公開鍵を入れる
DISCORD_PUBLIC_KEY=
# Application ID (Developer Portal の General Information → Application ID)
DISCORD_APPLICATION_ID=

# ---- Cloudflare DNS ----
# Zone:DNS:Edit 権限のみの API Token を Cloudflare dashboard で発行
# https://dash.cloudflare.com/profile/api-tokens
CLOUDFLARE_DNS_API_TOKEN=
# 対象 zone の ID (Cloudflare dashboard で zone を開いた時の右下)
CLOUDFLARE_ZONE_ID=
# FQDN 組み立てに使うベースドメイン (例: example.com → atm11.example.com)
CLOUDFLARE_BASE_DOMAIN=example.com

# ---- EC2 起動パラメータ ----
# Launch Template ID。`infra/tf.ps1 output launch_template_id` で取得。
EC2_LAUNCH_TEMPLATE_ID=lt-xxxxxxxxxxxxxxxxx
EC2_SUBNET_ID=subnet-xxxxxxxx

# ---- ATM11 固有 (Phase 1 hardcode) ----
ATM11_SNAPSHOT_ID=snap-xxxxxxxx
# Cloudflare DNS A レコード ID (事前に dashboard で atm11.<base-domain> を作成して取得)
ATM11_CF_RECORD_ID=
# RCON password を保管する SSM Parameter Store パス (SecureString で投入済み前提)
ATM11_RCON_PASSWORD_SSM_PATH=/gs/atm11/rcon_password

# ---- launcher 配布 (Phase 1) ----
# EC2 user-data が aws s3 cp で取得する tarball の S3 URI
# scripts/sync-launcher-to-s3.ps1 で upload する
LAUNCHER_TARBALL_S3_URI=s3://gs-game-configs/launcher/atm11.tar.gz

# ---- SNS → Discord 集約 (design.md §4.6) ----
# 受け付ける SNS Topic ARN。空なら全許可 (本番では必ず設定)
SNS_ALLOWED_TOPIC_ARN=arn:aws:sns:ap-northeast-1:111111111111:gs-alerts
# 通知投稿先の Discord channel webhook
# (Discord channel 設定 → Integrations → Webhooks で発行)
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/.../...
